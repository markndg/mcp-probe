          "result_schema": {
            "type": "object",
            "required": ["resources"],
            "properties": { "resources": { "type": "array" } }
          }
        }
      }
    ]
  },
  {
    "name": "pack:prompts_list",
    "steps": [
      {
        "send": { "method": "prompts/list", "params": {} },
        "expect": {
          "result_schema": {
